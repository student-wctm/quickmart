# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Database Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority

# Razorpay Payment Gateway Credentials
# Get your keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Telegram Bot Notifications
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ngrok Configuration (Optional - for mobile access)
# Get your permanent domain from: https://dashboard.ngrok.com/cloud-edge/domains
NGROK_DOMAIN=your-domain.ngrok-free.dev
FRONTEND_URL=https://your-domain.ngrok-free.dev
BACKEND_URL=https://your-domain.ngrok-free.dev/api
